# IBM Quantum Credentials Template
# ================================
# Copy this file to .env in the neuro_synthesis root directory
# and fill in your credentials.
#
# NEVER commit .env to git!
#
# cp cloud_job/env.template .env
# Then edit .env with your actual credentials

# Your IBM Quantum API token (from IBM Cloud)
IBM_QUANTUM_TOKEN=your_api_token_here

# Channel type (ibm_cloud for premium, ibm_quantum for open)
QISKIT_IBM_CHANNEL=ibm_cloud

# Your CRN (Cloud Resource Name) - for premium plan
QISKIT_IBM_INSTANCE=crn:v1:bluemix:public:quantum-computing:us-east:a/your_account:your_instance::

# IonQ (research/ionq scripts only)
IONQ_API_KEY=your_ionq_api_key_here

